%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% aas_macros.sty --- local stub
%
% Provides the standard AAS / NASA-ADS journal abbreviation macros so that
% BibTeX entries exported from ADS (which use \apj, \mnras, \aap, ...) can
% be compiled on any TeX installation.  Only the most common abbreviations
% are defined; add more below as needed.
%
% This file is kept local to the proposal so the project is self-contained
% and does not rely on aas_macros.sty being installed system-wide.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{aas_macros}[2026/04/16 v1.0 Local AAS journal abbreviations]

